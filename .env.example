# .env.example — copy to .env.local and fill in values

# Gemini API key (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Public URL of the deployed app (used in share attribution)
# In local dev this defaults to http://localhost:3000 automatically — leave blank
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Upstash Redis (get from https://upstash.com) — optional for local dev, required in production
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
